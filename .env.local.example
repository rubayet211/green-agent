# Required in production. Generate a long random value (at least 32 bytes).
ANONYMOUS_SESSION_SECRET=replace_with_a_long_random_secret

# Optional locally; enables the real Gemini multi-agent chain.
GEMINI_API_KEY=your_gemini_api_key_here

# Required in production. Development/test use a local file only when omitted.
# Replace private-key newlines with escaped \n characters.
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."

# Optional; missing values produce an explicitly simulated result with no fake IDs.
HEDERA_ACCOUNT_ID=0.0.xxxxx
HEDERA_PRIVATE_KEY=302e0201...
HEDERA_NETWORK=testnet
HEDERA_TOPIC_ID=0.0.xxxxx
